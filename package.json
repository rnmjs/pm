{
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "install": "pnpm build",
    "prepare": "fenge install",
    "release": "pnpm -r publish",
    "style": "fenge",
    "style:update": "fenge -u",
    "test": "pnpm style && pnpm typecheck && pnpm -r test",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "fenge": "0.13.1",
    "typescript": "5.9.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.19.0"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "10.28.1"
    }
  }
}
